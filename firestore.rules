rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Caregiver: full read/write to their own subtree
    match /caregivers/{caregiverId}/{document=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == caregiverId;
    }

    // Patient: read-only access to their linked caregiver's subtree
    match /caregivers/{caregiverId}/{document=**} {
      allow read: if request.auth != null
        && exists(/databases/$(database)/documents/patients/$(request.auth.uid))
        && get(/databases/$(database)/documents/patients/$(request.auth.uid))
             .data.linkedCaregiverId == caregiverId;
    }

    // Patient profile: only that patient can read/write their own profile
    match /patients/{patientId} {
      allow read, write: if request.auth != null
        && request.auth.uid == patientId;
    }

    // Invite code lookup for patient registration
    match /inviteCodes/{inviteCode} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.caregiverId == request.auth.uid;
    }

    // Invite code lookup: any authenticated user can read caregiver profiles
    // to look up an invite code during patient registration
    match /caregivers/{caregiverId}/profile {
      allow read: if request.auth != null;
    }
  }
}
